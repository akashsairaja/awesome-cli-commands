{
  "id": "ffmpeg-replace-audio",
  "categoryId": "ffmpeg",
  "subcategoryId": "ffmpeg-audio",
  "title": "Replace audio track",
  "command": "ffmpeg -i video.mp4 -i newaudio.mp3 -c:v copy -map 0:v:0 -map 1:a:0 output.mp4",
  "description": "Replace video's audio with new audio",
  "tags": ["replace", "audio", "track"]
}
