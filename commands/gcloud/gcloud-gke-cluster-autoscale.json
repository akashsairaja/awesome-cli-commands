{
  "id": "gcloud-gke-cluster-autoscale",
  "categoryId": "gcloud",
  "subcategoryId": "gcloud-gke",
  "title": "Enable Cluster Autoscaler",
  "command": "gcloud container clusters update <name> --zone=<zone> --enable-autoscaling --min-nodes=1 --max-nodes=10",
  "description": "Enable cluster-level autoscaling for the default node pool",
  "tags": ["gke", "autoscaling", "cluster"]
}
