{
  "id": "gcloud-gke-nodepool-autoscale",
  "categoryId": "gcloud",
  "subcategoryId": "gcloud-gke",
  "title": "Enable Node Pool Autoscaling",
  "command": "gcloud container node-pools update <pool-name> --cluster=<cluster> --zone=<zone> --enable-autoscaling --min-nodes=1 --max-nodes=10",
  "description": "Enable autoscaling on a node pool with min/max node counts",
  "tags": ["gke", "autoscaling", "node-pool"]
}
