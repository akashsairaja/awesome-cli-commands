{
  "id": "k8s-64",
  "categoryId": "kubernetes",
  "subcategoryId": "secrets",
  "title": "Decode all secrets",
  "command": "kubectl get secret <name> -o go-template='{{range $k,$v := .data}}{{$k}}: {{$v|base64decode}}{{\"\\n\"}}{{end}}'",
  "description": "Decode and display all secret values."
}
