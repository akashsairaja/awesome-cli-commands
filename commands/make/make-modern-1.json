{
  "id": "make-modern-1",
  "categoryId": "make",
  "subcategoryId": "make-modern",
  "title": "Self-documenting help",
  "command": "help:\n\t@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | sort | awk 'BEGIN {FS = \":.*?## \"}; {printf \"\\033[36m%-15s\\033[0m %s\\n\", $$1, $$2}'",
  "description": "Generate help from comments (## comment)."
}
