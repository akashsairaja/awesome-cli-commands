{
  "id": "zsh-list-colors",
  "categoryId": "zsh",
  "subcategoryId": "zsh-prompt",
  "title": "Show available colors",
  "command": "for i in {0..255}; do print -Pn \"%K{$i}  %k%F{$i}${(l:3::0:)i}%f \" ${${(M)$((i%6)):#3}:+$'\\n'}; done",
  "description": "Display all 256 terminal colors",
  "tags": ["colors", "palette", "terminal"]
}
