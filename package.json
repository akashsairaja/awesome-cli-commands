{
  "name": "awesome-cli-commands",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "validate": "node scripts/validate.mjs",
    "validate:commands": "node scripts/validate.mjs --only commands",
    "validate:recipes": "node scripts/validate.mjs --only recipes",
    "validate:agents": "node scripts/validate.mjs --only agents",
    "validate:skills": "node scripts/validate.mjs --only skills",
    "validate:rules": "node scripts/validate.mjs --only rules",
    "lint": "npm run lint:json && npm run lint:md",
    "lint:json": "prettier --check \"commands/**/*.json\" \"recipes/**/*.json\" \"schemas/**/*.json\"",
    "lint:md": "markdownlint-cli2",
    "lint:fix": "prettier --write \"commands/**/*.json\" \"recipes/**/*.json\" \"schemas/**/*.json\"",
    "commitlint": "commitlint --from origin/main --to HEAD",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "markdownlint-cli2": "^0.21.0",
    "prettier": "^3.8.1",
    "zod": "^4.3.6"
  }
}
