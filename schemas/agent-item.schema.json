{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentItem",
  "description": "Frontmatter schema for agent/skill/rule markdown files (content is the markdown body)",
  "type": "object",
  "required": [
    "id",
    "stackId",
    "type",
    "name",
    "description",
    "difficulty",
    "tags",
    "compatibility",
    "faq",
    "version",
    "lastUpdated"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "stackId": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["agent", "skill", "rule"]
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"]
    },
    "globs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "compatibility": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prerequisites": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "faq": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question", "answer"],
        "properties": {
          "question": {
            "type": "string"
          },
          "answer": {
            "type": "string"
          }
        }
      }
    },
    "relatedItems": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    },
    "lastUpdated": {
      "type": "string",
      "format": "date"
    }
  },
  "additionalProperties": false
}
